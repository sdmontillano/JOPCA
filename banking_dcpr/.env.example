# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite locally)
# For ElephantSQL: postgres://user:password@host:5432/dbname
# For Render PostgreSQL: postgres://user:password@host:5432/dbname
DATABASE_URL=

# CORS - comma-separated frontend URLs for production
# Example: http://localhost:3000,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=

# Environment
DJANGO_ENV=development
