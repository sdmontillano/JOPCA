# Django Settings - SECURITY IMPORTANT
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite locally)
# For ElephantSQL: postgres://user:password@host:5432/dbname
# For Render PostgreSQL: postgres://user:password@host:5432/dbname
DATABASE_URL=

# CORS - comma-separated frontend URLs for production
# Example: http://localhost:3000,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin User Creation (for create_default_admin endpoint)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=admin@jopca.local

# Environment
DJANGO_ENV=development
