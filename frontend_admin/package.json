{
  "name": "jopca",
  "productName": "JOPCA",
  "version": "1.0.0",
  "description": "JOPCA Banking - Daily Cash Position & PDC Management System",
  "main": "electron/main.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "vite build && electron-builder --win --publish never",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.jopca.app",
    "productName": "JOPCA",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "**/*",
      "!node_modules/**",
      "dist/**",
      "electron/**",
      "public/**"
    ],
    "extraResources": [
      {
        "from": "../banking_dcpr",
        "to": "banking_dcpr",
        "filter": [
          "**/*",
          "!venv/**",
          "!.env",
          "!__pycache__/**",
          "!.git/**"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/jopca-logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "JOPCA"
    }
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "axios": "^1.13.6",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jspdf-fonts": "^0.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  }
}
